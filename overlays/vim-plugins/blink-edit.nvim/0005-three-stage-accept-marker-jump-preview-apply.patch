+--- Return the position (1-indexed line, 0-indexed col) of the first eligible hunk, for cursor jumping
+---@param bufnr number
+---@param prediction BlinkEditPrediction
+---@return number|nil, number  -- line_1, col_0
+function M.get_first_hunk_pos(bufnr, prediction)
+  local snapshot = prediction.snapshot_lines
+  local predicted = prediction.predicted_lines
+  local window_start = prediction.window_start or 1
+  if not snapshot or not predicted then return nil, 0 end
+  local diff_result = diff.compute(snapshot, predicted)
+  if not diff_result.has_changes or #diff_result.hunks == 0 then return nil, 0 end
+  local cursor_offset = 1
+  if prediction.cursor then
+    cursor_offset = prediction.cursor[1] - window_start + 1
+    cursor_offset = math.max(1, cursor_offset)
+  end
+  local first_hunk = nil
+  for _, hunk in ipairs(diff_result.hunks) do
+    local anchor = hunk.start_old
+    if hunk.type == "insertion" then anchor = hunk.start_old + 1 end
+    if anchor >= cursor_offset then first_hunk = hunk; break end
+  end
+  if not first_hunk and prediction.allow_fallback then first_hunk = diff_result.hunks[1] end
+  if not first_hunk then return nil, 0 end
+  local line_1 = window_start + first_hunk.start_old - 1
+  local line_count = vim.api.nvim_buf_line_count(bufnr)
+  line_1 = math.max(1, math.min(line_1, line_count))
+  local col_0 = 0
+  if first_hunk.type == "modification" and first_hunk.line_changes and first_hunk.line_changes[1] then
+    col_0 = first_hunk.line_changes[1].change.col or 0
+  end
+  return line_1, col_0
+end
+
 --- Show prediction as ghost text
 --- Uses vim.diff() to properly identify insertions, deletions, and modifications
 --- Only shows changes at or below cursor position (next-edit semantics)
@@ -323,6 +357,33 @@ function M.show(bufnr, prediction)
     return
   end
 
+  -- Marker stage: only show the jump indicator, no full preview
+  if prediction.stage == "marker" then
+    extmarks[bufnr] = extmarks[bufnr] or {}
+    local cursor_offset = 1
+    if cursor then
+      cursor_offset = cursor[1] - window_start + 1
+      cursor_offset = math.max(1, cursor_offset)
+    end
+    local dr = diff.compute(snapshot, predicted)
+    if dr.has_changes and #dr.hunks > 0 then
+      local first_hunk = nil
+      for _, hunk in ipairs(dr.hunks) do
+        local anchor = hunk.start_old
+        if hunk.type == "insertion" then anchor = hunk.start_old + 1 end
+        if anchor >= cursor_offset then first_hunk = hunk; break end
+      end
+      if not first_hunk and prediction.allow_fallback then first_hunk = dr.hunks[1] end
+      if first_hunk then
+        show_jump_indicator(bufnr, first_hunk, window_start, extmarks[bufnr])
+      end
+    end
+    if visibility.on_show and extmarks[bufnr] and #extmarks[bufnr] > 0 then
+      visibility.on_show(bufnr)
+    end
+    return
+  end
+
   if prediction.accept_queue and #prediction.accept_queue > 0 then
     local delta = prediction.accept_queue_delta or 0
     local shown_count = 0
@@ -416,7 +477,7 @@ function M.show(bufnr, prediction)
     end
 
     if first_hunk then
-      show_jump_indicator(bufnr, first_hunk, window_start, extmarks[bufnr])
+      show_jump_indicator(bufnr, first_hunk, window_start, extmarks[bufnr], "BlinkEditJumpActive")
     end
 
     if visibility.on_show and extmarks[bufnr] and #extmarks[bufnr] > 0 then
@@ -513,7 +574,7 @@ function M.show(bufnr, prediction)
   end
 
   if first_hunk then
-    show_jump_indicator(bufnr, first_hunk, window_start, extmarks[bufnr])
+    show_jump_indicator(bufnr, first_hunk, window_start, extmarks[bufnr], "BlinkEditJumpActive")
   end
 
   if visibility.on_show and extmarks[bufnr] and #extmarks[bufnr] > 0 then
