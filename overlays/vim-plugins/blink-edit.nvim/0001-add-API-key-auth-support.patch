From 68d67414b39adf23384b31daa4cb0e1c3018d3b1 Mon Sep 17 00:00:00 2001
From: Alexander Sosedkin <asosedkin@redhat.com>
Date: Thu, 5 Mar 2026 00:12:43 +0000
Subject: [PATCH 1/5] add API key auth support

---
 lua/blink-edit/backends/openai.lua | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/lua/blink-edit/backends/openai.lua b/lua/blink-edit/backends/openai.lua
index 1d8ac2e..304c97c 100644
--- a/lua/blink-edit/backends/openai.lua
+++ b/lua/blink-edit/backends/openai.lua
@@ -40,6 +40,7 @@ function M.complete(opts, callback)
     method = "POST",
     headers = {
       ["Content-Type"] = "application/json",
+      ["Authorization"] = cfg.llm.api_key and ("Bearer " .. cfg.llm.api_key) or nil,
     },
     body = vim.json.encode(request_body),
     timeout = cfg.llm.timeout_ms,
@@ -101,6 +102,9 @@ function M.health_check(callback)
   transport.request({
     url = cfg.llm.url .. endpoint,
     method = "GET",
+    headers = {
+      ["Authorization"] = cfg.llm.api_key and ("Bearer " .. cfg.llm.api_key) or nil,
+    },
     timeout = 2000,
   }, function(err, response)
     if err then
