From 60b2b21e6b4c84579d631bc63a9a1ec9567013be Mon Sep 17 00:00:00 2001
From: Alexander Sosedkin <monk@unboiled.info>
Date: Thu, 14 May 2026 11:25:51 +0000
Subject: [PATCH] 0009-flash-attn-cutlass-include

---
 cmake/external_projects/vllm_flash_attn.cmake | 19 +++++++++++++++++++
 1 file changed, 19 insertions(+)

diff --git a/cmake/external_projects/vllm_flash_attn.cmake b/cmake/external_projects/vllm_flash_attn.cmake
index b38917a..f88de66 100644
--- a/cmake/external_projects/vllm_flash_attn.cmake
+++ b/cmake/external_projects/vllm_flash_attn.cmake
@@ -57,6 +57,25 @@ install(CODE "set(CMAKE_INSTALL_PREFIX \"\${CMAKE_INSTALL_PREFIX}/vllm/\")" ALL_
 FetchContent_MakeAvailable(vllm-flash-attn)
 message(STATUS "vllm-flash-attn is available at ${vllm-flash-attn_SOURCE_DIR}")
 
+# flash-attn's csrc/cutlass is a git submodule absent from the tarball.
+# Wire in nixpkgs cutlass (FETCHCONTENT_SOURCE_DIR_CUTLASS) so headers
+# are found at compile time regardless of FetchContent source resolution.
+if(DEFINED FETCHCONTENT_SOURCE_DIR_CUTLASS)
+  foreach(_fa_tgt _vllm_fa2_C _vllm_fa3_C)
+    if(TARGET ${_fa_tgt})
+      target_include_directories(${_fa_tgt} PRIVATE
+        ${FETCHCONTENT_SOURCE_DIR_CUTLASS}/include)
+    endif()
+  endforeach()
+endif()
+
+# When no SM90+ architectures are targeted, the patched flash-attn cmake
+# skips _vllm_fa3_C. Create a no-op placeholder so setup.py's
+# "cmake --build --target _vllm_fa3_C" succeeds without building anything.
+if(NOT TARGET _vllm_fa3_C)
+  add_custom_target(_vllm_fa3_C)
+endif()
+
 # Restore the install prefix after FA's install rules
 install(CODE "set(CMAKE_INSTALL_PREFIX \"\${OLD_CMAKE_INSTALL_PREFIX}\")" ALL_COMPONENTS)
 install(CODE "set(CMAKE_INSTALL_LOCAL_ONLY TRUE)" ALL_COMPONENTS)
