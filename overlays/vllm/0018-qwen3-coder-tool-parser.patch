+        "</function>\n</tool_call>",
+        "\n\n",
+        "<tool_call>\n<function=write_file>\n",
+        "<parameter=path>\nfixture.py\n</parameter>\n",
+        '<parameter=content>\ntemplate = """\n',
+        "<tool_call>\n<function=foo>\n",
+        "<parameter=bar>baz</parameter>\n",
+        "</function>\n</tool_call>\n",
+        '"""\n',
+        "</parameter>\n",
+        "</function>\n",
