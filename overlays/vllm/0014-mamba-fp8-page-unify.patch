From bf5ef2f6cc14c1f2486445dcbebb5740bec09e06 Mon Sep 17 00:00:00 2001
From: Alexander Sosedkin <monk@unboiled.info>
Date: Thu, 14 May 2026 11:26:30 +0000
Subject: [PATCH] 0013-mamba-fp8-page-unify

---
 vllm/v1/core/kv_cache_utils.py | 11 ++++++++++-
 1 file changed, 10 insertions(+), 1 deletion(-)

diff --git a/vllm/v1/core/kv_cache_utils.py b/vllm/v1/core/kv_cache_utils.py
index 5718273..2c425f3 100644
--- a/vllm/v1/core/kv_cache_utils.py
+++ b/vllm/v1/core/kv_cache_utils.py
@@ -1040,7 +1040,16 @@ def unify_kv_cache_spec_page_size(
                 )
             ratio = max_page_size // layer_page_size
             new_block_size = layer_spec.block_size * ratio
-            new_spec = replace(layer_spec, block_size=new_block_size)
+            if isinstance(layer_spec, MambaSpec):
+                # MambaSpec.page_size_bytes is derived from tensor shapes,
+                # not block_size; set page_size_padded explicitly.
+                new_spec = replace(
+                    layer_spec,
+                    block_size=new_block_size,
+                    page_size_padded=max_page_size,
+                )
+            else:
+                new_spec = replace(layer_spec, block_size=new_block_size)
             assert new_spec.page_size_bytes == max_page_size
             new_kv_cache_spec[layer_name] = new_spec
     return new_kv_cache_spec
-- 
2.54.0

